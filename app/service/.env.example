# Índice OpenCV da câmera (macOS: 0=webcam interna, 1=Logitech C925e USB)
CAMERA_DEVICE_INDEX=1

# Endereço de bind do socket ZMQ PUSH
ZMQ_ENDPOINT=tcp://0.0.0.0:5555

# Path local do modelo YOLO (baixado via ultralytics na primeira execução)
YOLO_MODEL_PATH=yolov8n.pt

# Score mínimo de confiança para incluir detecção no payload (0.01–0.99)
CONFIDENCE_THRESHOLD=0.5

# Resolução alvo de captura da câmera
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# Resolução de inferência YOLO (redimensionamento interno para performance)
INFERENCE_WIDTH=640
INFERENCE_HEIGHT=480

# Qualidade de codificação JPEG do frame publicado (1–100)
JPEG_QUALITY=85

# Porta HTTP da API de health/config
HTTP_PORT=8000

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
